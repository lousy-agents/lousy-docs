---
// biome-ignore lint/correctness/noUnusedImports: used in Astro HTML template
import Search from "astro-pagefind/components/Search";
import "../styles/global.css";

interface Props {
    title: string;
    description?: string;
}

// biome-ignore lint/correctness/noUnusedVariables: used in Astro HTML template
const { title, description = "Documentation for the Lousy Agents ecosystem." } =
    Astro.props;

// biome-ignore lint/correctness/noUnusedVariables: used in Astro HTML template
const cfBeaconToken = import.meta.env.PUBLIC_CF_BEACON_TOKEN;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link
            rel="preconnect"
            href="https://fonts.gstatic.com"
            crossorigin=""
        />
        <link
            rel="stylesheet"
            href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Manrope:wght@400;500;600;700&display=swap"
        />
        <link
            rel="stylesheet"
            href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
        />
        <title>{title}</title>
    </head>
    <body>
        <slot />
        <div
            id="search-overlay"
            class="search-overlay"
            data-pagefind-ignore="all"
        >
            <div class="search-overlay__backdrop"></div>
            <div class="search-overlay__panel" role="dialog" aria-label="Search documentation">
                <Search
                    id="search"
                    className="pagefind-ui analog-terminal"
                    uiOptions={{
                        showSubResults: true,
                        showImages: false,
                        resetStyles: false,
                    }}
                />
            </div>
        </div>
        <script is:inline>
            (function () {
                var overlay = document.getElementById("search-overlay");
                var panel = overlay && overlay.querySelector(".search-overlay__panel");

                function openSearch() {
                    if (!overlay) return;
                    overlay.classList.add("search-overlay--open");
                    document.body.style.overflow = "hidden";
                    var input = overlay.querySelector(".pagefind-ui__search-input");
                    if (input) {
                        input.focus();
                        input.select();
                    }
                }

                function closeSearch() {
                    if (!overlay) return;
                    overlay.classList.remove("search-overlay--open");
                    document.body.style.overflow = "";
                }

                window.addEventListener("open-search", openSearch);

                if (overlay) {
                    overlay.addEventListener("click", function (e) {
                        if (panel && !panel.contains(e.target)) {
                            closeSearch();
                        }
                    });
                }

                document.addEventListener("keydown", function (e) {
                    if ((e.metaKey || e.ctrlKey) && e.key === "k") {
                        e.preventDefault();
                        if (overlay && overlay.classList.contains("search-overlay--open")) {
                            closeSearch();
                        } else {
                            openSearch();
                        }
                    }
                    if (e.key === "Escape" && overlay && overlay.classList.contains("search-overlay--open")) {
                        closeSearch();
                    }
                });
            })();
        </script>
        <script is:inline>
            document.addEventListener("DOMContentLoaded", function () {
                try {
                    var script = document.createElement("script");
                    script.type = "module";
                    script.textContent =
                        "try { await import('/pagefind/pagefind-highlight.js'); new PagefindHighlight({ highlightParam: 'highlight' }); } catch(e) {}";
                    document.head.appendChild(script);
                } catch (e) {
                    // Highlight script is optional; fail silently during dev
                }
            });
        </script>
        {cfBeaconToken && (
            <script
                defer
                src="https://static.cloudflareinsights.com/beacon.min.js"
                data-cf-beacon={JSON.stringify({ token: cfBeaconToken })}
            ></script>
        )}
    </body>
</html>
